{
  "name": "@wolf-cup/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "dev": "node --watch dist/index.js",
    "build": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "seed": "tsx src/db/seed.ts",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "clear:demo": "tsx scripts/clear-demo.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.0.0",
    "@libsql/client": "^0.17.0",
    "@spicygolf/ghin": "^0.8.8",
    "@wolf-cup/engine": "workspace:*",
    "bcrypt": "^5.1.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "drizzle-kit": "^0.30.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
