# tournament-api environment configuration
#
# Copy to apps/tournament-api/.env for local dev. Production values come
# from the VPS /opt/wolf-cup/.env file (loaded by docker-compose).
#
# All vars are validated by Zod at module load — see src/lib/env.ts.

# Required: T1-1
NODE_ENV=development
DB_PATH=./data/tournament.db

# Required: T1-6a auth (cookie scope + CSRF origin check). No defaults
# permitted — silent misconfiguration is worse than failing to start.
AUTH_COOKIE_DOMAIN=localhost
PUBLIC_APP_URL=http://localhost:5173

# Required: T1-6b Google OAuth client credentials. Get from Google Cloud
# Console → Credentials → OAuth 2.0 Client IDs.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Required: T2-3 Anthropic Vision API key for the scorecard-PDF parser.
# Get from https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# Optional: T2-3.2 auto-organizer-promotion on container start. Empty
# default → no-op. Set to a Google `sub` to auto-promote that player to
# organizer on every container start. Idempotent.
ORGANIZER_GOOGLE_SUB=

# Optional: T1-7 logging. Defaults: LOG_LEVEL=info, LOG_DIR=./data/logs
# in dev (or /app/data/logs in production).
LOG_LEVEL=
LOG_DIR=

# GHIN API credentials (T3-4). Optional — when both are missing or
# empty, the /api/players/search and /api/players/lookup endpoints
# return 503 service_unavailable. Set both to enable GHIN lookups.
GHIN_USERNAME=
GHIN_PASSWORD=
