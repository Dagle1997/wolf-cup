{
  "name": "@tournament/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "dev": "node --watch dist/index.js",
    "build": "tsc",
    "db:generate": "node scripts/drizzle-kit.mjs generate",
    "db:migrate": "node scripts/drizzle-kit.mjs migrate",
    "seed": "tsx src/db/seed.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "@aws-sdk/client-s3": "3.1042.0",
    "@aws-sdk/s3-request-presigner": "3.1042.0",
    "@hono/node-server": "^1.0.0",
    "@libsql/client": "^0.17.0",
    "arctic": "^3.7.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.0.0",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.0",
    "pino-roll": "^4.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.17.6",
    "drizzle-kit": "^0.30.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
